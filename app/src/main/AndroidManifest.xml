<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Continuous voice capture for the always-on assistant. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Keep the socket + capture alive when the screen is off (PRD §5.5). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- Persistent "Assistant is listening" notification on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Coarse location → reverse-geocoded to "City, Country" for profile context. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:name=".App"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Taskade_mobile">
        <!-- Launcher + auth gate. Routes to login when there is no session, then
             lands authenticated users on the DIVYA chat screen. -->
        <activity
            android:name=".ChatActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- First-run onboarding (name / location / check-in hour). Reached from
             the auth gate when the profile isn't onboarded yet. -->
        <activity
            android:name=".OnboardingActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".TasksActivity"
            android:exported="false" />

        <activity
            android:name=".TaskDetailActivity"
            android:exported="false" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false" />

        <!-- Profile / logout home. No longer the launcher; reachable from a dock
             button in a later iteration. -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <activity
            android:name=".SignupActivity"
            android:exported="false" />

        <!--
          Hosts the live voice session (WebSocket + mic capture + playback) so the
          conversation survives screen-off / backgrounding. Declared with both the
          microphone and dataSync foreground service types (PRD §5.5).
        -->
        <service
            android:name=".voice.VoiceForegroundService"
            android:exported="false"
            android:foregroundServiceType="microphone|dataSync" />

        <!-- Receives FCM reminder pushes from the backend delivery sweep. -->
        <service
            android:name=".notifications.TaskadeMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- FCM defaults used when a notification is shown while the app is in the
             background (foreground messages are built by NotificationHelper). -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="task_reminders" />
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_icon"
            android:resource="@drawable/ic_stat_reminder" />
    </application>

</manifest>