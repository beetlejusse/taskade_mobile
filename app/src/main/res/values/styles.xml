<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================ -->
    <!--  Type scale                                                  -->
    <!--  Display text (titles, brand, hero numbers) → Space Grotesk  -->
    <!--  UI / body text → Plus Jakarta Sans                          -->
    <!-- ============================================================ -->
    <style name="TextAppearance.Taskade.Display" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/grotesk_bold</item>
        <item name="android:fontFamily">@font/grotesk_bold</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Taskade.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/grotesk_bold</item>
        <item name="android:fontFamily">@font/grotesk_bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Taskade.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/grotesk_bold</item>
        <item name="android:fontFamily">@font/grotesk_bold</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.Taskade.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/jakarta</item>
        <item name="android:fontFamily">@font/jakarta</item>
        <item name="android:textFontWeight">400</item>
    </style>

    <style name="TextAppearance.Taskade.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/jakarta</item>
        <item name="android:fontFamily">@font/jakarta</item>
        <item name="android:textFontWeight">400</item>
    </style>

    <style name="TextAppearance.Taskade.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/jakarta_semibold</item>
        <item name="android:fontFamily">@font/jakarta_semibold</item>
    </style>

    <!-- Title used on the auth sheet -->
    <style name="TextAppearance.Taskade.AuthTitle" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/grotesk_bold</item>
        <item name="android:fontFamily">@font/grotesk_bold</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Taskade.AuthSubtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/jakarta_medium</item>
        <item name="android:fontFamily">@font/jakarta_medium</item>
        <item name="android:textColor">@color/muted</item>
    </style>

    <!-- ============================================================ -->
    <!--  Shapes                                                      -->
    <!-- ============================================================ -->
    <!-- Top-only rounded corners for the bottom sheet card -->
    <style name="ShapeAppearance.Taskade.Sheet" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">32dp</item>
        <item name="cornerSizeTopRight">32dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="ShapeAppearance.Taskade.Field" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">18dp</item>
    </style>

    <!-- Fully circular overlay for the settings avatar (ShapeableImageView). -->
    <style name="ShapeAppearanceOverlay.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- ============================================================ -->
    <!--  Auth sheet card                                             -->
    <!-- ============================================================ -->
    <style name="Widget.Taskade.AuthSheet" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Taskade.Sheet</item>
        <!-- Kept low: the sheet moves with the IME, and a tall shadow re-composited
             every frame makes the floating-label animation visibly stutter. -->
        <item name="cardElevation">8dp</item>
        <item name="cardPreventCornerOverlap">false</item>
        <item name="contentPadding">0dp</item>
    </style>

    <!-- ============================================================ -->
    <!--  Text fields                                                 -->
    <!-- ============================================================ -->
    <!--
      Filled box with the underline indicator fully disabled (zero width in BOTH
      states) so no straight line ever cuts under the rounded fill. Filled mode is
      deliberate: its floating-label animation is plain text scale/translate,
      whereas outline mode recomputes the border cutout every frame and stutters.
      Focus is signalled by the label itself turning violet (hintTextColor).
    -->
    <style name="Widget.Taskade.TextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/field_fill</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="android:textColorHint">@color/muted</item>
        <item name="endIconTint">@color/muted</item>
        <item name="errorTextColor">@color/danger</item>
        <item name="errorIconTint">@color/danger</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Taskade.Field</item>
        <item name="boxCornerRadiusTopStart">18dp</item>
        <item name="boxCornerRadiusTopEnd">18dp</item>
        <item name="boxCornerRadiusBottomStart">18dp</item>
        <item name="boxCornerRadiusBottomEnd">18dp</item>
        <item name="hintTextAppearance">@style/TextAppearance.Taskade.BodyMedium</item>
    </style>

    <style name="Widget.Taskade.TextInputEditText" parent="Widget.Material3.TextInputEditText.FilledBox">
        <item name="android:textAppearance">@style/TextAppearance.Taskade.BodyLarge</item>
        <item name="android:textColor">@color/ink</item>
        <!-- Asymmetric padding: extra top room for the collapsed floating label so
             it never overlaps the typed text; Material's box handles the rest. -->
        <item name="android:paddingTop">26dp</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <!-- Settings list row card — flat surface with a hairline edge. Zero elevation
         on purpose: stacked rows each casting a shadow read as smudges on the
         canvas, so the crisp stroke does the separating instead. -->
    <style name="Widget.Taskade.SettingsRow" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="rippleColor">@color/ripple_primary</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>

    <!-- ============================================================ -->
    <!--  Buttons                                                     -->
    <!-- ============================================================ -->
    <style name="Widget.Taskade.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textAppearance">@style/TextAppearance.Taskade.LabelLarge</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="elevation">0dp</item>
        <item name="rippleColor">@color/on_primary</item>
    </style>

    <!-- Soft (tonal) button: violet tint fill, violet label -->
    <style name="Widget.Taskade.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textAppearance">@style/TextAppearance.Taskade.LabelLarge</item>
        <item name="backgroundTint">@color/primary_soft</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="iconTint">@color/primary</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">10dp</item>
        <item name="rippleColor">@color/ripple_primary</item>
    </style>

    <style name="Widget.Taskade.Button.Google" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAppearance">@style/TextAppearance.Taskade.LabelLarge</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">28dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="iconTint">@null</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">12dp</item>
        <item name="rippleColor">@color/outline</item>
    </style>

    <style name="Widget.Taskade.Button.Link" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAppearance">@style/TextAppearance.Taskade.BodyMedium</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">@color/outline</item>
    </style>

    <!-- ============================================================ -->
    <!--  Task detail label / value pairs                             -->
    <!-- ============================================================ -->
    <style name="Widget.Taskade.DetailLabel" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">@font/jakarta_semibold</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">12sp</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="Widget.Taskade.DetailValue" parent="">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:fontFamily">@font/jakarta_medium</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>
