<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================ -->
    <!--  Type scale — every appearance re-routes Material3 to        -->
    <!--  Montserrat so the family is consistent across all widgets.  -->
    <!-- ============================================================ -->
    <style name="TextAppearance.Taskade.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/montserrat</item>
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="android:textFontWeight">700</item>
    </style>

    <style name="TextAppearance.Taskade.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/montserrat</item>
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="android:textFontWeight">700</item>
    </style>

    <style name="TextAppearance.Taskade.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/montserrat</item>
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="android:textFontWeight">400</item>
    </style>

    <style name="TextAppearance.Taskade.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/montserrat</item>
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="android:textFontWeight">400</item>
    </style>

    <style name="TextAppearance.Taskade.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/montserrat</item>
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="android:textFontWeight">600</item>
    </style>

    <!-- Title used on the auth sheet -->
    <style name="TextAppearance.Taskade.AuthTitle" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/montserrat</item>
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="android:textFontWeight">700</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.Taskade.AuthSubtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/montserrat</item>
        <item name="android:fontFamily">@font/montserrat</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textColor">@color/muted</item>
    </style>

    <!-- ============================================================ -->
    <!--  Shapes                                                      -->
    <!-- ============================================================ -->
    <!-- Top-only rounded corners for the bottom sheet card -->
    <style name="ShapeAppearance.Taskade.Sheet" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">34dp</item>
        <item name="cornerSizeTopRight">34dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="ShapeAppearance.Taskade.Field" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Fully circular overlay for the settings avatar (ShapeableImageView). -->
    <style name="ShapeAppearanceOverlay.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- ============================================================ -->
    <!--  Auth sheet card                                             -->
    <!-- ============================================================ -->
    <style name="Widget.Taskade.AuthSheet" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/cream_surface</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Taskade.Sheet</item>
        <item name="cardElevation">18dp</item>
        <item name="cardPreventCornerOverlap">false</item>
        <item name="contentPadding">0dp</item>
    </style>

    <!-- ============================================================ -->
    <!--  Text fields                                                 -->
    <!-- ============================================================ -->
    <style name="Widget.Taskade.TextInputLayout" parent="Widget.Material3.TextInputLayout.FilledBox">
        <item name="boxBackgroundColor">@color/field_fill</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">1.5dp</item>
        <item name="hintTextColor">@color/muted</item>
        <item name="android:textColorHint">@color/muted</item>
        <item name="endIconTint">@color/muted</item>
        <item name="errorTextColor">@color/danger</item>
        <item name="errorIconTint">@color/danger</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Taskade.Field</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="hintTextAppearance">@style/TextAppearance.Taskade.BodyMedium</item>
        <item name="android:minHeight">60dp</item>
    </style>

    <style name="Widget.Taskade.TextInputEditText" parent="Widget.Material3.TextInputEditText.FilledBox">
        <item name="android:textAppearance">@style/TextAppearance.Taskade.BodyLarge</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:paddingTop">18dp</item>
        <item name="android:paddingBottom">18dp</item>
    </style>

    <!-- Settings list row card -->
    <style name="Widget.Taskade.SettingsRow" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/cream_surface</item>
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1dp</item>
        <item name="rippleColor">@color/ripple_primary</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- ============================================================ -->
    <!--  Buttons                                                     -->
    <!-- ============================================================ -->
    <style name="Widget.Taskade.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textAppearance">@style/TextAppearance.Taskade.LabelLarge</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="elevation">0dp</item>
        <item name="rippleColor">@color/on_primary</item>
    </style>

    <style name="Widget.Taskade.Button.Google" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAppearance">@style/TextAppearance.Taskade.LabelLarge</item>
        <item name="android:textColor">@color/ink</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/outline</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">18dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="iconTint">@null</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">12dp</item>
        <item name="rippleColor">@color/outline</item>
    </style>

    <style name="Widget.Taskade.Button.Link" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAppearance">@style/TextAppearance.Taskade.BodyMedium</item>
        <item name="android:textColor">@color/muted</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="rippleColor">@color/outline</item>
    </style>
</resources>
