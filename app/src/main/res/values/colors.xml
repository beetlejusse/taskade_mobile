<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!-- ============================================================ -->
    <!--  "Iris" palette — cool porcelain neutrals + electric violet  -->
    <!-- ============================================================ -->

    <!-- App canvas behind every screen: porcelain with a whisper of lavender -->
    <color name="canvas">#F5F4FB</color>
    <!-- Slightly deeper canvas used for top fades / pressed neutrals -->
    <color name="canvas_deep">#ECEAF6</color>
    <!-- Card / sheet surface -->
    <color name="surface">#FFFFFFFF</color>
    <!-- Input field fill -->
    <color name="field_fill">#F1EFF9</color>
    <!-- Hairline outline for inputs and dividers -->
    <color name="outline">#E7E4F2</color>

    <!-- Primary action — electric violet -->
    <color name="primary">#6C5CE7</color>
    <color name="primary_pressed">#5A4BD1</color>
    <color name="on_primary">#FFFFFFFF</color>
    <!-- Lighter companion used as the top stop of accent gradients -->
    <color name="primary_bright">#8B7CFF</color>
    <!-- Soft violet tint for chips, active nav, icon tiles (~10% primary on white) -->
    <color name="primary_soft">#EEEBFF</color>

    <!-- Text -->
    <color name="ink">#1A1826</color>
    <color name="muted">#7B7791</color>
    <color name="danger">#E5484D</color>
    <color name="danger_soft">#FDEDEE</color>
    <color name="warning">#F5A524</color>

    <!-- Glassmorphism (dock) — frosted white with a cool violet cast -->
    <color name="glass_surface">#C2FFFFFF</color>
    <color name="glass_highlight">#66FFFFFF</color>
    <color name="glass_stroke">#8FFFFFFF</color>
    <!-- Tint laid over the live blur so it reads as cool frosted glass -->
    <color name="glass_overlay">#66F7F5FF</color>
    <!-- Lighter variant for the standalone nav dock: less milk, more see-through
         blur, so the glass effect reads stronger. -->
    <color name="glass_overlay_light">#40F7F5FF</color>

    <!-- Chat bubbles -->
    <color name="bubble_agent">#FFFFFFFF</color>
    <color name="bubble_agent_text">#1A1826</color>
    <color name="bubble_user">#6C5CE7</color>
    <color name="bubble_user_text">#FFFFFFFF</color>

    <!-- Presence / success -->
    <color name="online">#22B573</color>

    <!-- Bounded card ripple (~12% primary) -->
    <color name="ripple_primary">#1F6C5CE7</color>

    <!-- Info / metadata card (the task-details card in chat) -->
    <color name="info">#4F7DF9</color>
    <color name="info_surface">#124F7DF9</color>
    <color name="info_stroke">#2E4F7DF9</color>
</resources>
