<?xml version="1.0" encoding="utf-8"?>
<!--
  Task-details card (backend `metadata` channel). Left-aligned like an agent reply;
  the body is populated programmatically by ChatAdapter since the number of tasks
  and links varies.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="18dp"
    android:paddingVertical="7dp">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginEnd="26dp"
        app:cardBackgroundColor="@color/info_surface"
        app:cardCornerRadius="18dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/info_stroke"
        app:strokeWidth="1dp">

        <LinearLayout
            android:id="@+id/metaContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="14dp" />
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
