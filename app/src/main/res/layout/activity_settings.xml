<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/canvas"
    tools:context=".SettingsActivity">

    <!-- Content the dock blurs as it scrolls beneath the frosted pills. -->
    <eightbitlab.com.blurview.BlurTarget
        android:id="@+id/blurTarget"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.core.widget.NestedScrollView
            android:id="@+id/settingsScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/canvas"
            android:clipToPadding="false"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/settingsContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="28dp">

                <!-- ===== Avatar header ===== -->
                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/settingsAvatar"
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_gravity="center_horizontal"
                    android:clickable="true"
                    android:contentDescription="@string/settings_avatar"
                    android:focusable="true"
                    android:foreground="@drawable/bg_avatar_ripple"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_avatar_placeholder"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Circle"
                    app:strokeColor="@color/primary_soft"
                    app:strokeWidth="3dp" />

                <TextView
                    android:id="@+id/settingsName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/grotesk_bold"
                    android:letterSpacing="-0.01"
                    android:text="@string/settings_user_name"
                    android:textColor="@color/ink"
                    android:textSize="24sp" />

                <TextView
                    android:id="@+id/settingsEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="3dp"
                    android:layout_marginBottom="28dp"
                    android:fontFamily="@font/jakarta_medium"
                    android:text="@string/settings_user_email"
                    android:textColor="@color/muted"
                    android:textSize="13sp" />

                <!-- ===== Settings rows ===== -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/rowProfile"
                    style="@style/Widget.Taskade.SettingsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <include layout="@layout/view_settings_row" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/rowNotifications"
                    style="@style/Widget.Taskade.SettingsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <include layout="@layout/view_settings_row" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/rowPrivacy"
                    style="@style/Widget.Taskade.SettingsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <include layout="@layout/view_settings_row" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/rowAppearance"
                    style="@style/Widget.Taskade.SettingsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <include layout="@layout/view_settings_row" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/rowAbout"
                    style="@style/Widget.Taskade.SettingsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <include layout="@layout/view_settings_row" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/rowSignOut"
                    style="@style/Widget.Taskade.SettingsRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <include layout="@layout/view_settings_row" />
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </eightbitlab.com.blurview.BlurTarget>

    <!-- Declared after the BlurTarget so it draws on top; no extra elevation —
         parent Z inflates the pill's shadow into a smear across the canvas. -->
    <com.app.taskade_mobile.ui.GlassNavDockView
        android:id="@+id/dock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
