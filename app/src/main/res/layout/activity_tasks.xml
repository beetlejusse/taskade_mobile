<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tasksRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige_background"
    tools:context=".TasksActivity">

    <!-- Content the dock blurs as it scrolls beneath the frosted pill. -->
    <eightbitlab.com.blurview.BlurTarget
        android:id="@+id/blurTarget"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/beige_background">

            <!-- ===== Fixed header: greeting + view toggle ===== -->
            <LinearLayout
                android:id="@+id/tasksHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:background="@color/beige_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="22dp"
                android:paddingTop="18dp"
                android:paddingEnd="22dp"
                android:paddingBottom="14dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:text="@string/tasks_greeting"
                        android:textColor="@color/muted"
                        android:textFontWeight="500"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tasksUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat"
                        android:letterSpacing="0.01"
                        android:textColor="@color/ink"
                        android:textFontWeight="700"
                        android:textSize="28sp"
                        tools:text="Vishal" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/viewToggleButton"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_toggle_button"
                    android:contentDescription="@string/tasks_toggle_view"
                    android:padding="11dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_list_view"
                    app:tint="@color/ink" />
            </LinearLayout>

            <!-- ===== Scrollable task listing (grid / list) ===== -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/taskList"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clipToPadding="false"
                android:paddingHorizontal="15dp"
                android:paddingTop="6dp"
                android:scrollbars="none"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tasksHeader"
                tools:listitem="@layout/item_task_grid" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </eightbitlab.com.blurview.BlurTarget>

    <!-- ===== Persistent glassmorphism dock (highest z-index) ===== -->
    <com.app.taskade_mobile.ui.DockView
        android:id="@+id/dock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
