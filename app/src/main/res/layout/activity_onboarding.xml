<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/onboardingRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/canvas"
    tools:context=".OnboardingActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="96dp"
            android:paddingEnd="28dp"
            android:paddingBottom="40dp">

            <TextView
                android:id="@+id/stepLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_kicker_chip"
                android:fontFamily="@font/jakarta_semibold"
                android:letterSpacing="0.12"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:text="@string/onboarding_kicker"
                android:textAllCaps="true"
                android:textColor="@color/primary"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/promptText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/grotesk_bold"
                android:letterSpacing="-0.02"
                android:lineSpacingMultiplier="1.05"
                android:text="@string/onboarding_name_prompt"
                android:textColor="@color/ink"
                android:textSize="30sp" />

            <TextView
                android:id="@+id/hintText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/jakarta_medium"
                android:lineSpacingMultiplier="1.25"
                android:text="@string/onboarding_name_hint"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputLayout"
                style="@style/Widget.Taskade.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:hint="@string/onboarding_answer_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/inputField"
                    style="@style/Widget.Taskade.TextInputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:imeOptions="actionDone"
                    android:inputType="textPersonName|textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/micButton"
                style="@style/Widget.Taskade.Button.Tonal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/onboarding_speak"
                app:icon="@android:drawable/ic_btn_speak_now" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/primaryButton"
                style="@style/Widget.Taskade.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/onboarding_continue" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/secondaryButton"
                style="@style/Widget.Taskade.Button.Link"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/onboarding_not_now"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/skipButton"
        style="@style/Widget.Taskade.Button.Link"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:text="@string/onboarding_skip" />

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminateTint="@color/primary"
        android:visibility="gone"
        tools:visibility="visible" />

</FrameLayout>
