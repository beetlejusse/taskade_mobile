<?xml version="1.0" encoding="utf-8"?>
<!-- Shared settings row content. Icon/title/subtitle are bound per-row in code
     (scoped via each card's findViewById, so the repeated ids don't clash). -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="68dp"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp">

    <ImageView
        android:id="@+id/rowIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_icon_tile"
        android:contentDescription="@null"
        android:padding="9dp"
        android:src="@drawable/ic_person"
        app:tint="@color/primary" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/rowTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/jakarta_semibold"
            android:textColor="@color/ink"
            android:textSize="15sp"
            tools:text="Profile" />

        <TextView
            android:id="@+id/rowSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:ellipsize="end"
            android:fontFamily="@font/jakarta_medium"
            android:maxLines="1"
            android:textColor="@color/muted"
            android:textSize="12sp"
            tools:text="Edit name, avatar and bio" />
    </LinearLayout>

    <ImageView
        android:id="@+id/rowChevron"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginStart="12dp"
        android:contentDescription="@string/settings_chevron"
        android:src="@drawable/ic_chevron_right"
        app:tint="@color/muted" />
</LinearLayout>
