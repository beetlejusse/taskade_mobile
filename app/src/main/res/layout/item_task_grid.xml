<?xml version="1.0" encoding="utf-8"?>
<!-- Task card — grid (2-column) presentation. -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/taskCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="7dp"
    android:minHeight="162dp"
    app:cardBackgroundColor="@color/cream_surface"
    app:cardCornerRadius="22dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/taskStatusChip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_chip"
                android:fontFamily="@font/montserrat"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/muted"
                android:textFontWeight="600"
                android:textSize="11sp"
                tools:text="In progress" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <View
                android:id="@+id/taskPriority"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/bg_priority_dot" />
        </LinearLayout>

        <TextView
            android:id="@+id/taskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:ellipsize="end"
            android:fontFamily="@font/montserrat"
            android:maxLines="2"
            android:textColor="@color/ink"
            android:textFontWeight="700"
            android:textSize="16sp"
            tools:text="Design review" />

        <TextView
            android:id="@+id/taskDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:fontFamily="@font/montserrat"
            android:lineSpacingMultiplier="1.1"
            android:maxLines="2"
            android:textColor="@color/muted"
            android:textFontWeight="500"
            android:textSize="13sp"
            tools:text="Finalize the DIVYA chat UI polish" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:contentDescription="@string/tasks_due"
                android:src="@drawable/ic_calendar"
                app:tint="@color/muted" />

            <TextView
                android:id="@+id/taskDueText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:fontFamily="@font/montserrat"
                android:textColor="@color/muted"
                android:textFontWeight="500"
                android:textSize="12sp"
                tools:text="Today · 5 PM" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
