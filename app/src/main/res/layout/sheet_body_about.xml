<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/aboutVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/jakarta"
        android:text="@string/settings_version"
        android:textColor="@color/muted"
        android:textFontWeight="500"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/aboutSupport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/jakarta"
        android:minHeight="48dp"
        android:gravity="center_vertical"
        android:text="@string/settings_support"
        android:textColor="@color/ink"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/aboutFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/jakarta"
        android:minHeight="48dp"
        android:gravity="center_vertical"
        android:text="@string/settings_feedback"
        android:textColor="@color/ink"
        android:textSize="15sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/sheetCloseButton"
        style="@style/Widget.Taskade.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/settings_close" />
</LinearLayout>
