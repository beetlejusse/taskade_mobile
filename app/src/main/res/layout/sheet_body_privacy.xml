<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/privacyVisibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/jakarta"
        android:minHeight="52dp"
        android:text="@string/settings_privacy_visibility"
        android:textColor="@color/ink"
        android:textSize="15sp" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/privacyAnalytics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/jakarta"
        android:minHeight="52dp"
        android:text="@string/settings_privacy_analytics"
        android:textColor="@color/ink"
        android:textSize="15sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/sheetSaveButton"
        style="@style/Widget.Taskade.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/settings_save_changes" />
</LinearLayout>
