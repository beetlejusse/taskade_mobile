<?xml version="1.0" encoding="utf-8"?>
<!--
  TASKADE adaptive-icon foreground: microphone + voice waveform.
  Authored in a 512-space mark (bbox center 276,257.5) and scaled 0.2x into the
  108 canvas so all key art stays inside the adaptive-icon safe zone.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <group
        android:scaleX="0.2" android:scaleY="0.2"
        android:translateX="-1.2" android:translateY="2.5">

        <!-- Microphone body -->
        <path
            android:fillColor="#FBF5EA"
            android:pathData="M194,158 A44,44 0 0 1 238,202 L238,256 A44,44 0 0 1 194,300 A44,44 0 0 1 150,256 L150,202 A44,44 0 0 1 194,158 Z" />
        <!-- Mic stand (U arc) -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#FBF5EA"
            android:strokeWidth="22"
            android:strokeLineCap="round"
            android:pathData="M118,262 A76,76 0 0 0 270,262" />
        <!-- Mic stem -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#FBF5EA"
            android:strokeWidth="22"
            android:strokeLineCap="round"
            android:pathData="M194,338 L194,374" />
