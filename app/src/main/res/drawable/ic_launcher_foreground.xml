            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="365" android:startY="141"
                    android:endX="365" android:endY="319">
                    <item android:offset="0" android:color="#FFE8B45C" />
                    <item android:offset="1" android:color="#FFC8862F" />
                </gradient>
