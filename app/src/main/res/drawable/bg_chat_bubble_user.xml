    android:shape="rectangle">
    <solid android:color="@color/bubble_user" />
    <corners
        android:topLeftRadius="20dp"
        android:topRightRadius="6dp"
        android:bottomRightRadius="20dp"
        android:bottomLeftRadius="20dp" />
</shape>
