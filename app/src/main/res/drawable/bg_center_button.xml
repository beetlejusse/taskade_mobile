<?xml version="1.0" encoding="utf-8"?>
<!-- Prominent circular voice/keyboard button at the center of the dock. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <gradient
        android:angle="90"
        android:startColor="@color/primary"
        android:endColor="@color/primary_pressed"
        android:type="linear" />
    <stroke
        android:width="2dp"
        android:color="@color/glass_stroke" />
</shape>
