<?xml version="1.0" encoding="utf-8"?>
<!--
  Expanding "sonar" ring emitted from the voice orb while the assistant is taking
  mic input. Transparent fill + a colored stroke so it reads as a clean ring; the
  stroke colour is re-tinted at runtime by DockView (espresso when listening,
  green while capturing speech).
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    <solid android:color="@android:color/transparent" />
    <stroke
        android:width="2.5dp"
        android:color="@color/primary" />
</shape>
