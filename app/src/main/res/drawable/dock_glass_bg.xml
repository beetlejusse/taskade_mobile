<?xml version="1.0" encoding="utf-8"?>
<!--
  Frosted-glass background for the dock. A translucent sheen gradient over a
  semi-transparent cream surface plus a light top stroke simulates the
  glassmorphism look while letting the chat content show softly through.
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="34dp" />
            <gradient
                android:angle="90"
                android:startColor="@color/glass_surface"
                android:endColor="@color/glass_highlight"
                android:type="linear" />
            <stroke
                android:width="1.5dp"
                android:color="@color/glass_stroke" />
        </shape>
    </item>
</layer-list>
